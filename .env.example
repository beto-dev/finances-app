# AI Providers (al menos uno requerido)
APP_ANTHROPIC_API_KEY=        # Claude Haiku — parser primario
GROQ_API_KEY=                 # Groq — fallback 1
GEMINI_API_KEY=               # Google Gemini — fallback 2

# Supabase
SUPABASE_URL=                 # https://xxxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Google OAuth (login + Google Sheets)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_LOGIN_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:8000/api/google/callback

# JWT
JWT_SECRET=change-this-secret-in-production
JWT_ALGORITHM=HS256

# URLs
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# Acceso (emails separados por coma — vacío = sin restricción)
ALLOWED_EMAILS=

# Solo local — nunca en producción
ENABLE_DEBUG_ENDPOINTS=true
